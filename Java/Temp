import org.junit.jupiter.api.Test;
import org.mockito.Mockito;

import javax.jms.Message;
import javax.jms.TextMessage;

import static org.mockito.Mockito.*;

class TImAckNackMessageListenerTest {

    private final AckNackPublisher ackNackPublisher = mock(AckNackPublisher.class);
    private final ObjectMapper objectMapper = new ObjectMapper();
    private final LoadingStore loadingStore = mock(LoadingStore.class);

    private final TImAckNackMessageListener listener = new TImAckNackMessageListener();

    @Test
    void testOnMessage_withMessageType() throws Exception {
        // Arrange
        TextMessage message = mock(TextMessage.class);
        when(message.getText()).thenReturn("sample-message");
        when(message.getStringProperty("MESSAGE_TYPE")).thenReturn("CUSTOM_TYPE");

        // Inject mocks
        listener.ackNackPublisher = ackNackPublisher;
        listener.objMapper = objectMapper;
        listener.loadingStore = loadingStore;

        // Act
        listener.onMessage(message);

        // Assert
        verify(ackNackPublisher, times(1))
                .publishMessage(any(TradeMessage.class), eq("CUSTOM_TYPE"));
    }

    @Test
    void testOnMessage_withNullMessageType_defaultsToPoolAllocation() throws Exception {
        // Arrange
        TextMessage message = mock(TextMessage.class);
        when(message.getText()).thenReturn("sample-message");
        when(message.getStringProperty("MESSAGE_TYPE")).thenReturn(null);

        listener.ackNackPublisher = ackNackPublisher;

        // Act
        listener.onMessage(message);

        // Assert
        verify(ackNackPublisher, times(1))
                .publishMessage(any(TradeMessage.class), eq("POOL_ALLOCATION"));
    }

    @Test
    void testOnMessage_withException() throws Exception {
        // Arrange
        TextMessage message = mock(TextMessage.class);
        when(message.getText()).thenThrow(new RuntimeException("Simulated error"));

        listener.ackNackPublisher = ackNackPublisher;

        // Act
        listener.onMessage(message);

        // Assert
        // Nothing thrown → handled by catch
        verifyNoInteractions(ackNackPublisher);
    }
}CLOSE db_cursor  
